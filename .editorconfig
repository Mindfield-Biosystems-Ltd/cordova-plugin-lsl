root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{js,ts}]
indent_style = space
indent_size = 4

[*.{java}]
indent_style = space
indent_size = 4

[*.{m,h}]
indent_style = space
indent_size = 4

[*.{c}]
indent_style = space
indent_size = 4

[*.{xml,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 4
